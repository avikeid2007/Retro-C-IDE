<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="C.Compiler.Controls.AIChatPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <Grid Background="#FF000088">
        <Grid.RowDefinitions>
            <!--  Top border  -->
            <RowDefinition Height="Auto" />
            <!--  Mode toggle (Ask / Agent)  -->
            <RowDefinition Height="Auto" />
            <!--  Chat messages  -->
            <RowDefinition Height="*" />
            <!--  Input area  -->
            <RowDefinition Height="Auto" />
            <!--  Bottom border  -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ═══ TOP BORDER ═══  -->
        <Grid Grid.Row="0" Height="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Height="2"
                VerticalAlignment="Center"
                Background="#FF00AAAA" />
            <Border
                Grid.Column="1"
                Height="2"
                VerticalAlignment="Center"
                Background="#FF00AAAA" />
            <TextBlock
                Grid.Column="2"
                Margin="6,0"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="13"
                FontWeight="Bold"
                Foreground="#FFFFFFFF"
                IsTextSelectionEnabled="False"
                Text="AI Assistant" />
            <Border
                Grid.Column="3"
                Height="2"
                VerticalAlignment="Center"
                Background="#FF00AAAA" />
            <!--  Close panel button  -->
            <Button
                x:Name="ClosePanelBtn"
                Grid.Column="4"
                Width="24"
                Height="18"
                MinWidth="0"
                MinHeight="0"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Click="ClosePanel_Click"
                CornerRadius="0">
                <TextBlock
                    FontFamily="Consolas"
                    FontSize="11"
                    Foreground="#FF00AAAA"
                    Text="[X]" />
            </Button>
        </Grid>

        <!--  ═══ MODE TOGGLE ═══  -->
        <Grid Grid.Row="1" Margin="4,4,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="AskModeBtn"
                Grid.Column="0"
                Height="24"
                MinWidth="0"
                MinHeight="0"
                Padding="4,2"
                HorizontalAlignment="Stretch"
                Background="#FF00AAAA"
                BorderBrush="#FF00AAAA"
                BorderThickness="1"
                Click="AskMode_Click"
                CornerRadius="0">
                <TextBlock
                    FontFamily="Consolas"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="#FF000000"
                    Text="Ask" />
            </Button>
            <Button
                x:Name="AgentModeBtn"
                Grid.Column="1"
                Height="24"
                MinWidth="0"
                MinHeight="0"
                Padding="4,2"
                HorizontalAlignment="Stretch"
                Background="#FF000055"
                BorderBrush="#FF00AAAA"
                BorderThickness="1"
                Click="AgentMode_Click"
                CornerRadius="0">
                <TextBlock
                    x:Name="AgentModeBtnText"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#FF00AAAA"
                    Text="Agent" />
            </Button>
            <Button
                x:Name="NewChatBtn"
                Grid.Column="2"
                Height="24"
                MinWidth="0"
                MinHeight="0"
                Margin="4,0,0,0"
                Padding="4,2"
                Background="Transparent"
                BorderBrush="#FF00AAAA"
                BorderThickness="1"
                Click="NewChat_Click"
                CornerRadius="0"
                ToolTipService.ToolTip="New Chat">
                <TextBlock
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#FF00AAAA"
                    Text="+" />
            </Button>
        </Grid>

        <!--  ═══ CHAT MESSAGES ═══  -->
        <ScrollViewer
            x:Name="ChatScrollViewer"
            Grid.Row="2"
            Margin="2,0"
            Padding="4,4"
            Background="#FF000088"
            VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChatMessagesPanel" Spacing="4" />
        </ScrollViewer>

        <!--  ═══ STATUS / LOADING ═══  -->
        <TextBlock
            x:Name="StatusText"
            Grid.Row="2"
            Margin="6,0,6,4"
            VerticalAlignment="Bottom"
            FontFamily="Consolas"
            FontSize="11"
            Foreground="#FF00AA00"
            Text=""
            Visibility="Collapsed" />

        <!--  ═══ INPUT AREA ═══  -->
        <Grid Grid.Row="3" Margin="4,2,4,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!--  Context chip bar  -->
            <StackPanel
                x:Name="ContextChips"
                Grid.Row="0"
                Margin="0,0,0,2"
                Orientation="Horizontal"
                Spacing="4"
                Visibility="Collapsed">
                <Border
                    Padding="4,1"
                    Background="#FF005588"
                    CornerRadius="0">
                    <TextBlock
                        x:Name="ContextChipText"
                        FontFamily="Consolas"
                        FontSize="10"
                        Foreground="#FF00AAAA"
                        Text="📎 current file" />
                </Border>
            </StackPanel>
            <!--  Input row  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Attach context  -->
                <Button
                    x:Name="AttachBtn"
                    Grid.Column="0"
                    Width="28"
                    Height="28"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="#FF00AAAA"
                    BorderThickness="1"
                    Click="Attach_Click"
                    CornerRadius="0"
                    ToolTipService.ToolTip="Attach current file / selection / errors">
                    <TextBlock
                        FontFamily="Consolas"
                        FontSize="13"
                        Foreground="#FF00AAAA"
                        Text="📎" />
                </Button>
                <!--  Message input  -->
                <TextBox
                    x:Name="InputBox"
                    Grid.Column="1"
                    MinHeight="28"
                    MaxHeight="120"
                    Margin="4,0"
                    Padding="4,4"
                    AcceptsReturn="True"
                    Background="#FF000055"
                    BorderBrush="#FF00AAAA"
                    BorderThickness="1"
                    CornerRadius="0"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#FFFFFFFF"
                    KeyDown="InputBox_KeyDown"
                    PlaceholderForeground="#FF005588"
                    PlaceholderText="Ask about your code..."
                    TextWrapping="Wrap" />
                <!--  Send button  -->
                <Button
                    x:Name="SendBtn"
                    Grid.Column="2"
                    Width="28"
                    Height="28"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="0"
                    Background="#FF00AAAA"
                    BorderThickness="0"
                    Click="Send_Click"
                    CornerRadius="0"
                    ToolTipService.ToolTip="Send (Ctrl+Enter)">
                    <TextBlock
                        FontFamily="Consolas"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#FF000000"
                        Text="▶" />
                </Button>
            </Grid>
        </Grid>

        <!--  ═══ BOTTOM BORDER ═══  -->
        <Border
            Grid.Row="4"
            Height="2"
            Background="#FF00AAAA" />
    </Grid>
</UserControl>
