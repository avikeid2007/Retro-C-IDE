<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="C.Compiler.Controls.EditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <!--
        TC3 Editor Window — box-drawing border, no line numbers gutter,
        title centered in top border, line:col in bottom-left border,
        scroll arrows on right side and bottom
    -->
    <Grid Background="#FF0000AA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══ TOP BORDER ═══  -->
        <Grid Grid.Row="0" Height="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  [■] close icon  -->
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="13"
                Foreground="#FF00AAAA"
                IsTextSelectionEnabled="False">
                <Run Text="[" /><Run Foreground="#FF00AA00" Text=" ■ " /><Run Text="]" />
            </TextBlock>
            <!--  Left line (stretches)  -->
            <Border
                Grid.Column="1"
                Height="2"
                VerticalAlignment="Center"
                Background="#FF00AAAA" />
            <!--  Title  -->
            <TextBlock
                x:Name="TopBorderText"
                Grid.Column="2"
                Margin="6,0"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="13"
                IsTextSelectionEnabled="False">
                <Run
                    x:Name="TitleRun"
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text="NONAME00.C" />
            </TextBlock>
            <!--  Right line (stretches)  -->
            <Border
                Grid.Column="3"
                Height="2"
                VerticalAlignment="Center"
                Background="#FF00AAAA" />
            <!--  Close button overlay (invisible, sits on top of [■])  -->
            <Button
                x:Name="CloseBtn"
                Grid.Column="0"
                Width="38"
                Height="18"
                MinWidth="0"
                MinHeight="0"
                Padding="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Click="CloseButton_Click"
                Content="     "
                CornerRadius="0"
                Opacity="0" />
        </Grid>

        <!--  ═══ CODE EDITOR ═══  -->
        <Grid
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  Left gutter — thin cyan line like TC3  -->
            <Border
                Grid.Column="0"
                Width="2"
                Background="#FF005588" />
            <RichEditBox
                x:Name="CodeEditor"
                Grid.Column="1"
                Padding="6,2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                AcceptsReturn="True"
                Background="#FF000088"
                BorderThickness="0"
                CornerRadius="0"
                FontFamily="Consolas"
                FontSize="14"
                Foreground="#FFFFFF00"
                IsReadOnly="False"
                IsSpellCheckEnabled="False"
                IsTextPredictionEnabled="False"
                RequestedTheme="Dark"
                SelectionChanged="CodeEditor_SelectionChanged"
                SelectionFlyout="{x:Null}"
                SelectionHighlightColor="#FF005555"
                TextChanged="CodeEditor_TextChanged"
                TextWrapping="NoWrap">
                <RichEditBox.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            x:Name="AskAIMenuItem"
                            Click="AskAI_Click"
                            Text="Ask AI"
                            Visibility="Collapsed">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE946;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator x:Name="AskAISeparator" Visibility="Collapsed" />
                        <MenuFlyoutItem Click="ContextCut_Click" Text="Cut" />
                        <MenuFlyoutItem Click="ContextCopy_Click" Text="Copy" />
                        <MenuFlyoutItem Click="ContextPaste_Click" Text="Paste" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Click="ContextSelectAll_Click" Text="Select All" />
                    </MenuFlyout>
                </RichEditBox.ContextFlyout>
                <!--  Override WinUI 3 themed brushes so background stays dark-blue in all visual states  -->
                <RichEditBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackground" Color="#FF000088" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FF000088" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FF000088" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#FF000088" />
                </RichEditBox.Resources>
            </RichEditBox>
            <!--  Block cursor overlay (TC3 style)  -->
            <Border
                x:Name="BlockCursor"
                Grid.Column="1"
                Width="9"
                Height="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#FFFFFF55"
                IsHitTestVisible="False"
                Opacity="1" />
        </Grid>



        <!--  ═══ BOTTOM BORDER ═══  -->
        <Grid Grid.Row="2" Height="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="13"
                IsTextSelectionEnabled="False">
                <Run Foreground="#FF00AAAA" Text="─*─  " />
                <Run
                    x:Name="BottomLineColRun"
                    Foreground="#FFFFFF55"
                    Text="1:1" />
            </TextBlock>
            <!--  Right line (stretches)  -->
            <Border
                Grid.Column="1"
                Height="2"
                VerticalAlignment="Center"
                Background="#FF00AAAA" />
        </Grid>
    </Grid>
</UserControl>
