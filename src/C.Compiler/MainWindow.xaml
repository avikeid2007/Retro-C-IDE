<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="C.Compiler.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:C.Compiler.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:C.Compiler"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Turbo C"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="#FF0000AA">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!--  ═══════════════════════════════════════════════  -->
        <!--  ROW 0: MENU BAR — Gray bg, RED hotkey letters  -->
        <!--  Matches TC3: ≡ File Edit Search Run ...  -->
        <!--  ═══════════════════════════════════════════════  -->
        <Grid
            x:Name="MenuBarGrid"
            Grid.Row="0"
            Background="#FFAAAAAA">
            <StackPanel
                x:Name="MenuBarPanel"
                VerticalAlignment="Stretch"
                Orientation="Horizontal">
                <Button
                    x:Name="SysMenuBtn"
                    VerticalContentAlignment="Top"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="0">
                    <TextBlock
                        Margin="0"
                        Padding="0"
                        VerticalAlignment="Top"
                        FontFamily="Consolas"
                        FontSize="24"
                        Foreground="#FF000000"
                        Text=" ≡ " />
                </Button>
                <Button
                    x:Name="FileMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="1">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="F" /><Run Foreground="#FF000000" Text="ile " /></TextBlock>
                </Button>
                <Button
                    x:Name="EditMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="2">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="E" /><Run Foreground="#FF000000" Text="dit " /></TextBlock>
                </Button>
                <Button
                    x:Name="SearchMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="3">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="S" /><Run Foreground="#FF000000" Text="earch " /></TextBlock>
                </Button>
                <Button
                    x:Name="RunMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="4">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="R" /><Run Foreground="#FF000000" Text="un " /></TextBlock>
                </Button>
                <Button
                    x:Name="CompileMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="5">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="C" /><Run Foreground="#FF000000" Text="ompile " /></TextBlock>
                </Button>
                <Button
                    x:Name="DebugMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="6">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="D" /><Run Foreground="#FF000000" Text="ebug " /></TextBlock>
                </Button>
                <Button
                    x:Name="ProjectMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="7">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="P" /><Run Foreground="#FF000000" Text="roject " /></TextBlock>
                </Button>
                <Button
                    x:Name="OptionsMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="8">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="O" /><Run Foreground="#FF000000" Text="ptions " /></TextBlock>
                </Button>
                <Button
                    x:Name="WindowMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="9">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="W" /><Run Foreground="#FF000000" Text="indow " /></TextBlock>
                </Button>
                <Button
                    x:Name="HelpMenuBtn"
                    Click="MenuTitle_Click"
                    PointerEntered="MenuTitle_Hover"
                    Style="{StaticResource DosMenuTitleStyle}"
                    Tag="10">
                    <TextBlock FontFamily="Consolas" FontSize="20"><Run Text=" " /><Run Foreground="#FFFF0000" Text="H" /><Run Foreground="#FF000000" Text="elp " /></TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!--  ═══════════════════════════════════════════════  -->
        <!--  ROW 1: EDITOR + WATCH PANEL (vertical split)  -->
        <!--  ═══════════════════════════════════════════════  -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  EDITOR TABS — multiple editor windows  -->
            <TabView
                x:Name="EditorTabs"
                Grid.Row="0"
                VerticalAlignment="Stretch"
                AddTabButtonClick="EditorTabs_AddTabButtonClick"
                Background="#FF0000AA"
                IsAddTabButtonVisible="True"
                SelectionChanged="EditorTabs_SelectionChanged"
                TabCloseRequested="EditorTabs_TabCloseRequested">
                <TabView.Resources>
                    <SolidColorBrush x:Key="TabViewBackground" Color="#FF0000AA" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="#FF000088" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#FF0000AA" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="#FF00AAAA" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="#FFFFFFFF" />
                </TabView.Resources>
            </TabView>

            <!--  WATCH/MESSAGE PANEL — TC3 box-drawing border  -->
            <Grid
                x:Name="MessagePanel"
                Grid.Row="1"
                Height="140">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  Top border with title  -->
                <Grid Grid.Row="0">
                    <TextBlock
                        Padding="0,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="13"
                        Foreground="#FF00AAAA">
                        <Run Text="[" /><Run Foreground="#FF00AA00" Text=" ■ " /><Run Text="]" /><Run Text="═══════════════════════════════ " />
                        <Run
                            FontWeight="Bold"
                            Foreground="#FFFFFFFF"
                            Text="Message" />
                        <Run Text=" ═══════════════════════════════════════════════════════════════" />
                    </TextBlock>
                </Grid>
                <!--  Message content  -->
                <ScrollViewer
                    Grid.Row="1"
                    Padding="1"
                    Background="#FF00AAAA"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <ListView
                        x:Name="MessageList"
                        Padding="4,2"
                        Background="#FF00AAAA"
                        IsItemClickEnabled="True"
                        ItemClick="MessageList_ItemClick"
                        SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Padding="0,0"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    Foreground="#FF000000"
                                    Text="{Binding}"
                                    TextWrapping="NoWrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
                <!--  Bottom border with scroll indicator  -->
                <TextBlock
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    FontFamily="Consolas"
                    FontSize="13"
                    Foreground="#FF00AAAA">
                    <Run Text=" ═══════════════════════════════════════════════════════════════════════════════════════════════" />
                </TextBlock>
            </Grid>
        </Grid>

        <!--  ═══════════════════════════════════════════════  -->
        <!--  ROW 2: STATUS BAR — exact TC3 layout  -->
        <!--  F1 Help  F7 Trace  F8 Step  ...  F10 Menu  -->
        <!--  ═══════════════════════════════════════════════  -->
        <Grid
            Grid.Row="2"
            Padding="2,0"
            Background="#FF00AAAA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="20"
                Foreground="#FF000000">
                <Run
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text=" F1" /><Run Text=" Help " />
                <Run Text=" " />
                <Run
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text="F2" /><Run Text=" Save " />
                <Run Text=" " />
                <Run
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text="F3" /><Run Text=" Open " />
                <Run Text=" " />
                <Run
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text="Alt+F9" /><Run Text=" Compile " />
                <Run Text=" " />
                <Run
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text="F9" /><Run Text=" Make " />
                <Run Text=" " />
                <Run
                    FontWeight="Bold"
                    Foreground="#FFFFFFFF"
                    Text="F10" /><Run Text=" Menu" />
            </TextBlock>
            <TextBlock
                x:Name="StatusLineCol"
                Grid.Column="1"
                Margin="8,0"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="12"
                FontWeight="Bold"
                Foreground="#FF000000"
                Text="1:1" />
        </Grid>

        <!--  ═══════════════════════════════════════════════  -->
        <!--  MENU DROPDOWN POPUPS  -->
        <!--  TC3 style: gray bg, black outer border,  -->
        <!--  solid black shadow, RED hotkey first letter  -->
        <!--  ═══════════════════════════════════════════════  -->

        <!--  ≡ System Menu  -->
        <Popup
            x:Name="MenuPopup0"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="180">
                        <Button Click="About_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="A" /><Run Text="bout...               " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="C" /><Run Text="lear Desktop           " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="R" /><Run Text="epaint Desktop         " /></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!--  File Menu  -->
        <Popup
            x:Name="MenuPopup1"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button Click="FileNew_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="N" /><Run Text="ew                     " /></TextBlock>
                        </Button>
                        <Button Click="FileOpen_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="O" /><Run Text="pen...            F3   " /></TextBlock>
                        </Button>
                        <Button Click="FileSave_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="S" /><Run Text="ave               F2   " /></TextBlock>
                        </Button>
                        <Button Click="FileSaveAs_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Save " /><Run Foreground="#FFFF0000" Text="a" /><Run Text="s...                  " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Save a" /><Run Foreground="#FFFF0000" Text="l" /><Run Text="l                    " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Click="ChangeDir_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="C" /><Run Text="hange dir...           " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="P" /><Run Text="rint                   " /></TextBlock>
                        </Button>
                        <Button Click="DosShell_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="D" /><Run Text="OS shell               " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Click="Quit_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="Q" /><Run Text="uit            Alt+X  " /></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!--  Edit Menu  -->
        <Popup
            x:Name="MenuPopup2"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Click="EditUndo_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="U" /><Run Text="ndo           Ctrl+Z    " /></TextBlock>
                        </Button>
                        <Button Click="EditRedo_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="R" /><Run Text="edo           Ctrl+Y    " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Click="EditCut_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Cu" /><Run Foreground="#FFFF0000" Text="t" /><Run Text="          Shift+Del   " /></TextBlock>
                        </Button>
                        <Button Click="EditCopy_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="C" /><Run Text="opy         Ctrl+Ins    " /></TextBlock>
                        </Button>
                        <Button Click="EditPaste_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="P" /><Run Text="aste        Shift+Ins   " /></TextBlock>
                        </Button>
                        <Button Click="EditClear_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" C" /><Run Foreground="#FFFF0000" Text="l" /><Run Text="ear         Ctrl+Del   " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Copy " /><Run Foreground="#FFFF0000" Text="e" /><Run Text="xample                " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="S" /><Run Text="how clipboard            " /></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!--  Search Menu  -->
        <Popup
            x:Name="MenuPopup3"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="280">
                        <Button Click="SearchFind_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="F" /><Run Text="ind...                    " /></TextBlock>
                        </Button>
                        <Button Click="SearchReplace_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="R" /><Run Text="eplace...                 " /></TextBlock>
                        </Button>
                        <Button Click="SearchAgain_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="S" /><Run Text="earch again               " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Click="GoToLine_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="G" /><Run Text="o to line number...       " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Find " /><Run Foreground="#FFFF0000" Text="p" /><Run Text="rocedure...              " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Find " /><Run Foreground="#FFFF0000" Text="e" /><Run Text="rror                     " /></TextBlock>
                        </Button>
                        <Button Click="PreviousError_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="P" /><Run Text="revious error    Alt+F7   " /></TextBlock>
                        </Button>
                        <Button Click="NextError_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="N" /><Run Text="ext error        Alt+F8   " /></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!--  Run Menu  -->
        <Popup
            x:Name="MenuPopup4"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Click="RunProgram_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="R" /><Run Text="un            Ctrl+F9  " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="P" /><Run Text="rogram reset  Ctrl+F2  " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="G" /><Run Text="o to cursor      F4    " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="T" /><Run Text="race into        F7    " /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="S" /><Run Text="tep over         F8    " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Click="RunArguments_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="A" /><Run Text="rguments...             " /></TextBlock>
                        </Button>
                        <Button Click="UserScreen_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="U" /><Run Text="ser screen    Alt+F5   " /></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!--  Compile Menu  -->
        <Popup
            x:Name="MenuPopup5"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="280">
                        <Button Click="Compile_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" Compile to " /><Run Foreground="#FFFF0000" Text="O" /><Run Text="BJ  Alt+F9  " /></TextBlock>
                        </Button>
                        <Button Click="Make_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="M" /><Run Text="ake EXE          F9    " /></TextBlock>
                        </Button>
                        <Button Click="LinkExe_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="L" /><Run Text="ink EXE file           " /></TextBlock>
                        </Button>
                        <Button Click="BuildAll_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="B" /><Run Text="uild all               " /></TextBlock>
                        </Button>
                        <Border
                            Height="1"
                            Margin="1,0"
                            Background="#FF555555" />
                        <Button Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="P" /><Run Text="rimary C file...       " /></TextBlock>
                        </Button>
                        <Button Click="GetInfo_Click" Style="{StaticResource DosMenuItemStyle}">
                            <TextBlock FontFamily="Consolas" FontSize="13"><Run Text=" " /><Run Foreground="#FFFF0000" Text="G" /><Run Text="et info                " /></TextBlock>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!--  Debug Menu  -->
        <Popup
            x:Name="MenuPopup6"
            Closed="MenuPopup_Closed"
            IsLightDismissEnabled="True">
            <Grid>
                <Border
                    Margin="3,3,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,3,3"
                    Background="#FFAAAAAA"
                    BorderBrush="#FF000000"
                    BorderThickness="1"
                    CornerRadius="0">
                    <StackPanel MinWidth="280">
                        <Button Style="{StaticResource DosMenuItemStyle}">
