                                FontSize="13"
                                Foreground="#FFFFFFFF"
                                PlaceholderText="e.g. input.txt 42" />
                        </StackPanel>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Click="DlgArguments_OK"
                                Content="  OK  "
                                Style="{StaticResource DosDialogButtonStyle}" />
                            <Button
                                Click="DlgArguments_Cancel"
                                Content="Cancel"
                                Style="{StaticResource DosDialogButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!--  DIRECTORIES DIALOG  -->
        <Grid
            x:Name="DirectoriesDialogOverlay"
            Grid.RowSpan="3"
            Background="Transparent"
            Visibility="Collapsed">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border
                    Margin="4,4,0,0"
                    Background="#FF000000"
                    CornerRadius="0" />
                <Border
                    Margin="0,0,4,4"
                    Padding="12"
                    Background="#FF0000AA"
                    BorderBrush="#FF00AAAA"
                    BorderThickness="2"
                    CornerRadius="0">
                    <StackPanel MinWidth="420" Spacing="8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Consolas"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#FF00AAAA"
                            Text="Directories" />
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#FFFFFF55"
                                Text="Include directories (;-separated):" />
                            <TextBox
                                x:Name="DlgDirInclude"
                                Background="#FF000055"
                                BorderBrush="#FF00AAAA"
                                BorderThickness="1"
                                CornerRadius="0"
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#FFFFFFFF" />
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#FFFFFF55"
                                Text="Library directories (;-separated):" />
                            <TextBox
                                x:Name="DlgDirLib"
                                Background="#FF000055"
                                BorderBrush="#FF00AAAA"
                                BorderThickness="1"
                                CornerRadius="0"
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#FFFFFFFF" />
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#FFFFFF55"
                                Text="Output directory:" />
                            <TextBox
                                x:Name="DlgDirOutput"
                                Background="#FF000055"
                                BorderBrush="#FF00AAAA"
                                BorderThickness="1"
                                CornerRadius="0"
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#FFFFFFFF"
                                PlaceholderText="same as source" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Click="DlgDirectories_OK"
                                Content="  OK  "
                                Style="{StaticResource DosDialogButtonStyle}" />
                            <Button
                                Click="DlgDirectories_Cancel"
                                Content="Cancel"
                                Style="{StaticResource DosDialogButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

